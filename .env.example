YOUTUBE_API_KEY=your_youtube_data_api_key

# 免費、不需信用卡：https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key

# GitHub Pages 網址（選填，預設為你的 repo Pages URL）
# SITE_BASE_URL=https://bebeboboha.github.io/ai_frontend_tool

